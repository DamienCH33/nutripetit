{% extends 'base/pwa.html.twig' %}

{% block title %}NutriPetit - Accueil
{% endblock %}

{% block body %}
	{# Hero greeting #}
	<section class="np-app-hero">
		<h1 class="np-app-hero__greeting">Bonjour.</h1>
		<p class="np-app-hero__subtitle">Prêt à scanner ?</p>
	</section>

	{# Invitation à renseigner l'âge (affichée seulement si non réglé) #}
	<a href="{{ path('app_pwa_baby_profile') }}" class="np-age-prompt" data-controller="age-prompt">
		{{ ux_icon('lucide:baby', {class: 'np-age-prompt__icon'}) }}
		<span>Renseignez l'âge de votre enfant pour des analyses adaptées.</span>
	</a>

	{# Card scan #}
	<a href="{{ path('app_pwa_scanner') }}" class="np-app-scan-card">
		<h2 class="np-app-scan-card__title">Scanner un produit</h2>

		<div class="np-app-scan-card__icon-wrapper">
			<svg class="np-app-scan-card__icon" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
				<path d="M3 7V5a2 2 0 0 1 2-2h2"/>
				<path d="M17 3h2a2 2 0 0 1 2 2v2"/>
				<path d="M21 17v2a2 2 0 0 1-2 2h-2"/>
				<path d="M7 21H5a2 2 0 0 1-2-2v-2"/>
				<line x1="7" y1="12" x2="17" y2="12"/>
			</svg>
		</div>

		<p class="np-app-scan-card__description">Pointez votre caméra vers le code-barres pour une analyse instantanée.</p>
	</a>

	{# Séparateur #}
	<div class="np-app-separator">ou</div>

	{# Saisie manuelle #}
	<a href="{{ path('app_pwa_manual_entry') }}" class="np-app-manual">
		<svg class="np-app-manual__icon" viewbox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
			<rect x="3" y="6" width="18" height="12" rx="2"/>
			<line x1="7" y1="10" x2="7" y2="14"/>
			<line x1="10" y1="10" x2="10" y2="14"/>
			<line x1="13" y1="10" x2="13" y2="14"/>
			<line x1="16" y1="10" x2="16" y2="14"/>
		</svg>
		Saisir le code-barres manuellement
	</a>

	{# Historique #}
	<section class="np-app-section">
		<div class="np-app-section__header">
			<h2 class="np-app-section__title">Vos derniers scans</h2>
			{% if recentScans|length > 0 %}
				<a href="{{ path('app_pwa_history') }}" class="np-app-section__link">Voir tout</a>
			{% endif %}
		</div>

		{% for scan in recentScans %}
			{% set circumference = 125.6 %}
			{% set offset = (100 - scan.finalScore) * 1.256 %}

			<a href="{{ path('app_pwa_scan', {ean: scan.product.ean}) }}" class="np-product-card">
				<div class="np-product-card__image">
					{% if scan.product.imageUrl %}
						<img src="{{ scan.product.imageUrl }}" alt="{{ scan.product.name }}">
					{% else %}
						{{ ux_icon('lucide:package', {class: 'np-product-card__image-icon'}) }}
					{% endif %}
				</div>

				<div class="np-product-card__content">
					<p class="np-product-card__brand">{{ scan.product.brand|default('-') }}</p>
					<p class="np-product-card__name">{{ scan.product.name }}</p>
					<p class="np-product-card__date">{{ scan.calculatedAt|date('d/m/Y à H:i') }}</p>
				</div>

				<div class="np-mini-score" aria-label="Score {{ scan.finalScore }} sur 100, {{ scan.level }}">
					<svg class="np-mini-score__svg" viewbox="0 0 48 48">
						<circle class="np-mini-score__bg" cx="24" cy="24" r="20"/>
						<circle class="np-mini-score__progress np-mini-score__progress--{{ scan.level }}" cx="24" cy="24" r="20" stroke-dasharray="{{ circumference }}" stroke-dashoffset="{{ offset }}"/>
					</svg>
					<span class="np-mini-score__value">{{ scan.finalScore }}</span>
				</div>
			</a>
		{% endfor %}
	</section>
{% endblock %}
