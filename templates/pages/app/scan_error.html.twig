{% extends 'base/pwa.html.twig' %}

{% block title %}{{ errorTitle }} - NutriPetit{% endblock %}

{% block body %}
<div class="np-scan-error">
    <div class="np-scan-error__icon-wrapper">
        {{ ux_icon('lucide:alert-circle', {class: 'np-scan-error__icon'}) }}
    </div>
    <h1 class="np-scan-error__title">{{ errorTitle }}</h1>
    <p class="np-scan-error__message">{{ errorMessage }}</p>

    <div class="np-scan-error__actions">
        <a href="{{ path('app_pwa_scanner') }}" class="np-scan-error__btn np-scan-error__btn--primary">
            {{ ux_icon('lucide:scan-line', {class: 'np-scan-error__btn-icon'}) }}
            Réessayer un scan
        </a>
        <a href="{{ path('app_pwa_manual_entry') }}" class="np-scan-error__btn np-scan-error__btn--secondary">
            {{ ux_icon('lucide:keyboard', {class: 'np-scan-error__btn-icon'}) }}
            Saisie manuelle
        </a>
        <a href="{{ path('app_pwa_home') }}" class="np-scan-error__btn np-scan-error__btn--ghost">
            Retour à l'accueil
        </a>
    </div>
</div>
{% endblock %}
