<!DOCTYPE html>
<html lang="fr">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
		<title>
			{% block title %}NutriPetit
			{% endblock %}
		</title>
		<meta name="description" content="{% block description %}Analyse nutritionnelle adaptée aux bébés et jeunes enfants.{% endblock %}">

		<meta name="theme-color" content="#FDF7F1">
		<meta name="apple-mobile-web-app-capable" content="yes">
		<meta name="mobile-web-app-capable" content="yes">
		<meta name="apple-mobile-web-app-status-bar-style" content="default">
		<meta name="apple-mobile-web-app-title" content="NutriPetit">

		<link rel="icon" type="image/svg+xml" href="{{ asset('images/logo/nutripetit.svg') }}">
		<link rel="manifest" href="{{ asset('manifest.json') }}">
		<link rel="apple-touch-icon" sizes="180x180" href="{{ asset('apple-touch-icon.png') }}">
		<link rel="icon" type="image/png" sizes="96x96" href="{{ asset('favicon-96x96.png') }}">
		<link rel="icon" type="image/svg+xml" href="{{ asset('favicon.svg') }}">

		{% block stylesheets %}
			{{ importmap('app') }}
		{% endblock %}
	</head>
	<body class="np-body--pwa">
		<div class="np-pwa-shell">
			{% block header %}
				{% include '_partials/_pwa_header.html.twig' %}
			{% endblock %}

			<main class="np-pwa-main"> {% block body %}{% endblock %}

				{# Disclaimer compact OBLIGATOIRE en bas de chaque page PWA #}
				{% block pwa_disclaimer %}
					{% include '_partials/_disclaimer_compact.html.twig' %}
				{% endblock %}
			</main>
		</div>

		{% block bottom_nav %}
			{% include '_partials/_pwa_bottom_nav.html.twig' %}
		{% endblock %}

		{% block javascripts %}{% endblock %}
	</body>
</html>
