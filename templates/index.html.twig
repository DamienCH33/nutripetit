{% extends 'base.html.twig' %}

{% block title %}
	NutriPetit - Scanner les produits bébé
{% endblock %}

{% block body %}

	<section class="home-hero">

		<div class="home-hero__content">

			<span class="home-badge">
				Nutrition bébé simplifiée
			</span>

			<h1 class="home-title">
				Comprendre rapidement
				les produits alimentaires
				pour bébé 👶
			</h1>

			<p class="home-description">
				Scannez un produit et obtenez instantanément
				une analyse claire adaptée aux bébés
				et jeunes enfants.
			</p>

			<div class="home-actions">

				<a href="#" class="np-button np-button--primary">
					Scanner un produit
				</a>

				<a href="#" class="np-button np-button--secondary">
					Comment ça marche
				</a>

			</div>

		</div>
		<div class="home-phone">

			<div class="scan-card">

				<div class="scan-card__header">

					<div class="scan-card__product">
						🥣 Petit Pot Carotte
					</div>

					<div class="scan-card__score">
						A
					</div>

				</div>

				<div class="scan-card__body">

					<div class="scan-item scan-item--good">
						✔ Faible teneur en sucre
					</div>

					<div class="scan-item scan-item--good">
						✔ Sans additif controversé
					</div>

					<div class="scan-item scan-item--warning">
						⚠ Texture peu adaptée avant 6 mois
					</div>

				</div>

			</div>

		</div>

	</section>

	<section class="features-section">

		<div class="section-heading">

			<span class="section-badge">
				Fonctionnalités
			</span>

			<h2>
				Une application pensée
				pour les parents
			</h2>

		</div>

		<div class="features-grid">

			<article class="feature-card">

				<div class="feature-icon">
					📷
				</div>

				<h3>
					Scan instantané
				</h3>

				<p>
					Analyse rapide des produits
					directement depuis le téléphone.
				</p>

			</article>

			<article class="feature-card">

				<div class="feature-icon">
					🧠
				</div>

				<h3>
					Score simplifié
				</h3>

				<p>
					Comprenez facilement si un produit
					est adapté à votre enfant.
				</p>

			</article>

			<article class="feature-card">

				<div class="feature-icon">
					🍼
				</div>

				<h3>
					Adapté aux bébés
				</h3>

				<p>
					Une analyse pensée spécifiquement
					pour les 0 à 3 ans.
				</p>

			</article>

		</div>

	</section>

	<section class="cta-section">

		<div class="cta-card">

			<div class="cta-content">

				<span class="section-badge">
					NutriPetit
				</span>

				<h2>
					Faites des choix
					plus simples au quotidien
				</h2>

				<p>
					NutriPetit aide les parents à mieux
					comprendre les produits alimentaires
					destinés aux bébés.
				</p>

			</div>

			<a href="#" class="np-button np-button--primary">
				Commencer maintenant
			</a>

		</div>

	</section>

{% endblock %}
